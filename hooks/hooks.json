{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/hooks/session-start.js\""
          }
        ],
        "description": "Load memory context on session start"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/hooks/session-end.js\""
          }
        ],
        "description": "Auto-save session status on stop"
      }
    ]
  }
}
